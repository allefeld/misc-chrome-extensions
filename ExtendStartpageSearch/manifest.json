{
    "manifest_version": 3,
    "name":         "Extend Startpage Search",
    "version":      "0.4",
    "description":  "Add links to other searches to Startpage Search",
    "icons": {
        "196": "startpage.png"
      },
    "content_scripts": [ {
        "exclude_globs":    [ ],
        "include_globs":    [ "*" ],
        "js":               [ "content.js" ],
        "matches":          [ "https://www.startpage.com/*/search*" ],
        "run_at": "document_idle"
    } ],
    "web_accessible_resources": [ {
        "resources": [ "icons/*" ],
        "matches": [ "https://www.startpage.com/*" ]
    } ]
}
